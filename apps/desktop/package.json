{
  "name": "@testcat/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev-app-name.mjs && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test:electron": "node scripts/electron-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "package": "electron-vite build && electron-builder",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx -e \"import { getStoreDatabase } from './src/main/store/db.ts'; const database = getStoreDatabase(); console.log('migrated ' + database.path); database.sqlite.close();\""
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@gsap/react": "^2.1.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@testcat/shared": "workspace:*",
    "better-sqlite3": "^12.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "gsap": "^3.15.0",
    "lucide-react": "^1.21.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "playwright": "^1.61.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.5"
  }
}
